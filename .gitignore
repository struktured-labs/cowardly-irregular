addons/gut/.gut_editor_*
.gut_editor_config.json

# Godot UID cache files
*.gd.uid

tmp/
setenv.sh
*APIkey*
.last_fetched_run
.last_synced_sha

# Claude Code (keep agents/, ignore session-specific files)
.claude/settings.local.json
.claude/worktrees/

# Butler / itch.io deploy binary
butler-bin/
butler.zip
*.zip
tmp/

# Music pipeline - keep OGG, ignore raw downloads and locks
assets/audio/music/*.mp3
assets/audio/music/*.wav
*.lock
captcha-key.txt
__pycache__/
tools/test_*.py

# Sprite pipeline intermediates — written by palette_lock.py /
# normalize_sprites.py as rollback backups. Not shipped (web
# export_presets excludes them via *.pre_*.png), not referenced by
# any manifest, and they belong to the cowir-sprites worktree.
# Excluded from git so the game repo doesn't carry ~70MB of derived
# artifacts, and so cowir-sprites can leave locally-usable backups
# in their working tree without dirtying commits here.
assets/sprites/**/*.pre_normalize.png
assets/sprites/**/*.pre_palette.png
assets/sprites/**/*.pre_chromakey.png
assets/sprites/**/*.pre_artist_style.png
