{
  "id": "world1_umbraxis_intro",
  "title": "Umbraxis, the Void Render",
  "world": 1,
  "trigger": "boss_shadow_dragon",
  "background": "shadow_cave",
  "description": "Boss intro for Umbraxis in the Abyssal Hollow. A philosophical shadow dragon who knows what it actually is.",
  "steps": [
    {
      "type": "stop_music"
    },
    {
      "type": "letterbox_in",
      "duration": 0.5
    },
    {
      "type": "play_sfx",
      "sfx": "boss_intro_stinger"
    },
    {
      "type": "boss_intro",
      "name": "Umbraxis",
      "title": "The Void Render"
    },
    {
      "type": "wait",
      "duration": 0.5
    },
    {
      "type": "narration",
      "lines": [
        "The shadows coalesce. Darkness becomes form.",
        "Two violet eyes open in the void."
      ]
    },
    {
      "type": "dialogue",
      "lines": [
        {
          "speaker": "Umbraxis",
          "text": "Interesting.",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Umbraxis",
          "text": "You came all the way down here.",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Umbraxis",
          "text": "Do you even know what I am?",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Fighter",
          "text": "A dragon?",
          "theme": "fighter",
          "portrait": "fighter"
        },
        {
          "speaker": "Umbraxis",
          "text": "I'm data. Arranged to look like a dragon.",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Umbraxis",
          "text": "And you're data arranged to look like a hero.",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Umbraxis",
          "text": "The only difference between us... is that I KNOW I'm just data.",
          "theme": "enemy",
          "portrait": "mysterious"
        },
        {
          "speaker": "Mage",
          "text": "...",
          "theme": "mage",
          "portrait": "mage"
        },
        {
          "speaker": "Umbraxis",
          "text": "Don't worry. It only hurts if you think about it.",
          "theme": "enemy",
          "portrait": "mysterious"
        }
      ]
    },
    {
      "type": "screen_shake",
      "duration": 0.3,
      "intensity": 3.0
    },
    {
      "type": "screen_flash",
      "duration": 0.15
    },
    {
      "type": "letterbox_out",
      "duration": 0.3
    }
  ]
}
